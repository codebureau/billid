<UserControl x:Class="WorkTracking.UI.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:WorkTracking.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SummaryViewModel}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">

            <!-- This year -->
            <TextBlock Text="This Year" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>

            <Grid Margin="0,0,0,6" MaxWidth="400" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Total hours" Margin="0,4"/>
                <TextBlock Grid.Row="0" Grid.Column="1"
                           Text="{Binding TotalHoursThisYear, StringFormat='{}{0:N2} h'}"
                           FontWeight="SemiBold" Margin="0,4"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Total invoiced" Margin="0,4"/>
                <TextBlock Grid.Row="1" Grid.Column="1"
                           Text="{Binding TotalInvoicedAmountThisYear, StringFormat='{}{0:C}'}"
                           FontWeight="SemiBold" Margin="0,4"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Uninvoiced hours" Margin="0,4"/>
                <TextBlock Grid.Row="2" Grid.Column="1"
                           Text="{Binding UninvoicedHours, StringFormat='{}{0:N2} h'}"
                           FontWeight="SemiBold" Margin="0,4"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Uninvoiced amount" Margin="0,4"/>
                <TextBlock Grid.Row="3" Grid.Column="1"
                           Text="{Binding UninvoicedAmount, StringFormat='{}{0:C}'}"
                           FontWeight="SemiBold" Margin="0,4"/>
            </Grid>

            <!-- Cap status -->
            <Border Visibility="{Binding HasCap, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,8,0,0" MaxWidth="400" HorizontalAlignment="Left"
                    Padding="10,7" CornerRadius="4" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#E8F5E9"/>
                        <Setter Property="BorderBrush" Value="#81C784"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsOverCap}" Value="True">
                                <Setter Property="Background" Value="#FFEBEE"/>
                                <Setter Property="BorderBrush" Value="#E57373"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="✓ Uninvoiced amount is within the invoice cap."/>
                            <Setter Property="Foreground" Value="#2E7D32"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverCap}" Value="True">
                                    <Setter Property="Text" Value="⚠ Uninvoiced amount exceeds the invoice cap."/>
                                    <Setter Property="Foreground" Value="#C62828"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>

            <!-- Frequency status -->
            <Border Visibility="{Binding HasFrequency, Converter={StaticResource BoolToVisibilityConverter}}"
                    Margin="0,8,0,0" MaxWidth="400" HorizontalAlignment="Left"
                    Padding="10,7" CornerRadius="4" BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#E3F2FD"/>
                        <Setter Property="BorderBrush" Value="#64B5F6"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FrequencyStatus}" Value="Due">
                                <Setter Property="Background" Value="#FFF8E1"/>
                                <Setter Property="BorderBrush" Value="#FFD54F"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding FrequencyStatus}" Value="Overdue">
                                <Setter Property="Background" Value="#FFEBEE"/>
                                <Setter Property="BorderBrush" Value="#E57373"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Next invoice due: " Foreground="#37474F"/>
                    <TextBlock Text="{Binding NextDueDate, StringFormat='{}{0:dd MMM yyyy}'}" FontWeight="SemiBold" Foreground="#37474F"/>
                    <TextBlock Text=" — " Foreground="#37474F"/>
                    <TextBlock Text="{Binding FrequencyStatusLabel}" FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1565C0"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FrequencyStatus}" Value="Due">
                                        <Setter Property="Foreground" Value="#E65100"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FrequencyStatus}" Value="Overdue">
                                        <Setter Property="Foreground" Value="#C62828"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Separator Margin="0,16,0,16"/>

            <!-- Hours per month -->
            <TextBlock Text="Hours per Month (This Year)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding HoursPerMonth}" MaxWidth="400" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:MonthlyHourLine}">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Month}" Foreground="Gray" FontSize="11"/>
                            <ProgressBar Grid.Column="1" Height="12" Minimum="0" Maximum="200"
                                         Value="{Binding Hours, Mode=OneWay}"
                                         Margin="4,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Hours, StringFormat='{}{0:N1} h'}"
                                       FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Separator Margin="0,16,0,16"/>

            <!-- Hours by category -->
            <TextBlock Text="Hours by Category (All Time)" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding HoursByCategory}" MaxWidth="400" HorizontalAlignment="Left">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:CategoryHourLine}">
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Category}" Foreground="Gray" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                            <ProgressBar Grid.Column="1" Height="12" Minimum="0" Maximum="200"
                                         Value="{Binding Hours, Mode=OneWay}"
                                         Margin="4,0"/>
                            <TextBlock Grid.Column="2" Text="{Binding Hours, StringFormat='{}{0:N1} h'}"
                                       FontSize="11" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</UserControl>
