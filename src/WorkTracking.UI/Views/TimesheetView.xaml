<UserControl x:Class="WorkTracking.UI.Views.TimesheetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:WorkTracking.UI.Converters"
             xmlns:vm="clr-namespace:WorkTracking.UI.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:TimesheetViewModel}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1"
                Padding="8,6" Background="#FAFAFA">
            <WrapPanel>
                <TextBlock Text="Period:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                <Button Content="This Month" Command="{Binding FilterThisMonthCommand}"
                        Margin="0,0,3,0" Padding="6,2" FontSize="11"/>
                <Button Content="Last Month" Command="{Binding FilterLastMonthCommand}"
                        Margin="0,0,3,0" Padding="6,2" FontSize="11"/>
                <Button Content="This Year" Command="{Binding FilterThisYearCommand}"
                        Margin="0,0,3,0" Padding="6,2" FontSize="11"/>
                <Button Content="All Time" Command="{Binding FilterAllTimeCommand}"
                        Margin="0,0,10,0" Padding="6,2" FontSize="11"/>

                <TextBlock Text="From:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                <DatePicker SelectedDate="{Binding FilterStartDate, UpdateSourceTrigger=PropertyChanged}"
                            Width="120" Margin="0,0,6,0"/>
                <TextBlock Text="To:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                <DatePicker SelectedDate="{Binding FilterEndDate, UpdateSourceTrigger=PropertyChanged}"
                            Width="120" Margin="0,0,10,0"/>

                <TextBlock Text="Show:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                <ComboBox ItemsSource="{Binding InvoicedFilterOptions}"
                          SelectedItem="{Binding InvoicedFilterText}"
                          Width="100" Margin="0,0,10,0"/>

                <TextBlock Text="Category:" VerticalAlignment="Center"
                           Margin="0,0,4,0" Foreground="Gray" FontSize="11"/>
                <ComboBox Width="150" Margin="0,0,10,0"
                          ItemsSource="{Binding CategoriesWithAll}"
                          DisplayMemberPath="Name"
                          SelectedItem="{Binding SelectedFilterCategory}"/>

                <ToggleButton Content="📝 Notes" IsChecked="{Binding IsNotesOpen}"
                              Padding="6,2" FontSize="11"/>

                <Separator Width="1" Height="18" Margin="10,0" Background="#CCC"/>

                <Button Content="+ Add entry" Command="{Binding AddEntryCommand}"
                        Margin="0,0,4,0" Padding="7,2" FontSize="11"/>
                <Button Content="✏ Edit" Command="{Binding EditEntryCommand}"
                        Margin="0,0,4,0" Padding="7,2" FontSize="11"/>
                <Button Content="🗑 Delete" Command="{Binding DeleteEntryCommand}"
                        Padding="7,2" FontSize="11"/>
            </WrapPanel>
        </Border>

        <!-- MAIN CONTENT: DataGrid + Notes Drawer -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- DATA GRID -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding SelectedEntry}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="False"
                      SelectionMode="Single"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Header=""
                        Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                        Width="30"/>
                    <DataGridTextColumn Header="Date"
                        Binding="{Binding Date, StringFormat='{}{0:dd MMM yyyy}'}"
                        Width="105" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Description"
                        Binding="{Binding Description}"
                        Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Hours"
                        Binding="{Binding Hours, StringFormat='{}{0:N1}'}"
                        Width="60" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Category"
                        Binding="{Binding CategoryName}"
                        Width="120" IsReadOnly="True"/>
                    <DataGridCheckBoxColumn Header="Invoiced"
                        Binding="{Binding IsInvoiced}"
                        Width="70" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Inv. Ref"
                        Binding="{Binding InvoiceRef}"
                        Width="80" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- NOTES DRAWER -->
            <Border Grid.Column="1"
                    BorderBrush="#DDD" BorderThickness="1,0,0,0"
                    Visibility="{Binding IsNotesOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top" Text="Notes"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,6"/>

                    <TextBlock DockPanel.Dock="Top"
                               Text="Select a row to view notes."
                               Foreground="Gray" FontStyle="Italic"
                               Visibility="{Binding HasSelectedEntry,
                                   Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <TextBox DockPanel.Dock="Top"
                             Text="{Binding SelectedEntry.NotesMarkdown, FallbackValue=''}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             MinHeight="100" MaxHeight="300"
                             IsReadOnly="True"
                             FontFamily="Consolas" FontSize="12"
                             BorderThickness="1" Padding="4"
                             Visibility="{Binding HasSelectedEntry,
                                 Converter={StaticResource BoolToVisibilityConverter}}"
                             Margin="0,0,0,10"/>

                    <TextBlock DockPanel.Dock="Top" Text="Attachments"
                               FontWeight="SemiBold" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock DockPanel.Dock="Top"
                               Text="No attachments."
                               Foreground="Gray" FontStyle="Italic" FontSize="11"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="#F5F5F5"
                BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="12,6">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Prepare Invoice…"
                        Command="{Binding PrepareInvoiceCommand}"
                        Padding="10,4" FontSize="12"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Uninvoiced total: " Foreground="Gray" FontSize="12"/>
                    <TextBlock FontSize="12" FontWeight="SemiBold" Margin="0,0,4,0">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="{}{0:N1} hrs  ·  ${1:N2}">
                                <Binding Path="TotalUninvoicedHours"/>
                                <Binding Path="TotalUninvoicedAmount"/>
                            </MultiBinding>
                        </TextBlock.Text>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverCap}" Value="True">
                                        <Setter Property="Foreground" Value="DarkRed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="⚠ Over cap  " Foreground="DarkRed" FontSize="12"
                               Visibility="{Binding IsOverCap,
                                   Converter={StaticResource BoolToVisibilityConverter}}"/>

                    <ItemsControl ItemsSource="{Binding CategorySummaryLines}" Margin="8,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding CategoryName}"
                                               Foreground="Gray" FontSize="11"/>
                                    <TextBlock Text=": " Foreground="Gray" FontSize="11"/>
                                    <TextBlock Text="{Binding Hours, StringFormat='{}{0:N1} hrs'}"
                                               FontSize="11"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
